# --- Required (production & local with Postgres) ---
# Start DB: `docker compose up -d` in this folder, then use URL below.
DATABASE_URL="postgresql://glow:glow_dev_change_me@127.0.0.1:5432/glowarena"

# Turn off legacy file-based POST /api/bookings (use v2 customer APIs only). Set in production.
DISABLE_LEGACY_BOOKING=1

# Sign cookies: platform admin session + customer auth. Use long random strings in production.
AUTH_SECRET=change-me-min-32-chars-random

# Platform admin login (/platform/admin and v2 admin APIs). Required when NODE_ENV=production.
ADMIN_SECRET=change-me-long-random-admin-password

# --- Payments: Razorpay (see web/docs/RAZORPAY.md) ---
# 1) Set KEY_ID + KEY_SECRET + WEBHOOK_SECRET from Razorpay Dashboard (test or live mode).
# 2) Register webhook URL: https://<your-host>/api/v2/payments/razorpay/webhook — event: payment.captured
# 3) Set NEXT_PUBLIC_RAZORPAY_ENABLED=1 and rebuild to show "Pay with Razorpay" on /platform/customer
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxx
# RAZORPAY_WEBHOOK_SECRET=xxxxxxxx
# NEXT_PUBLIC_RAZORPAY_ENABLED=1
# NEXT_PUBLIC_RAZORPAY_DISPLAY_NAME=Glow Arena

# Optional Google Analytics 4 measurement ID for `trackEvent` + Book / WhatsApp / Call clicks.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Set to 0 to hide the dismissible beta banner on every page.
# NEXT_PUBLIC_SHOW_BETA_BANNER=0

# Public site URL (https://your-domain.com) — used for sitemap, robots, and Open Graph base.
# Required in production for correct SEO URLs.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Booking confirmations (optional — if unset, API still saves the booking and returns skip reasons).
# RESEND_API_KEY=re_...
# BOOKING_FROM_EMAIL="Glow Arena <booking@your-verified-domain.com>"
# (Resend test sender: Glow Arena <onboarding@resend.dev>)

# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+1...   # or +91... your Twilio SMS-capable number

# Demo / QA: stress bookings (npm run prisma:seed:stress) use game ids prefixed stress-.
# Public availability hides them unless ?includeStress=1 on /api/v2/public/availability.
