# Public site URL (https://your-domain.com) — used for sitemap, robots, and Open Graph base.
# Required in production for correct SEO URLs.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Admin API secret. Required when NODE_ENV=production (admin routes return 503 if unset).
# In development, omit to leave admin APIs open.
# ADMIN_SECRET=your-long-random-string
